{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "storage.rules",
      "**/.*",
      "**/node_modules/**",
      "Thumbs.db",
      "Desktop.ini",
      "uploads/**",
      "Roadmap.pdf",
      "roadmap.md",
      "PLAN_OF_ACTION.md",
      "Strategy.md",
      "handoff_*.md",
      "Handoff and Spec Files/**",
      "firebase-debug.log",
      "public/**",
      "skills-lock.json"
    ],
    "rewrites": [
      { "source": "/", "destination": "/coming-soon/index.html" }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}